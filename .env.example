# 星图 Docker 部署环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== 数据存储 =====
# 数据持久化目录（宿主机路径）
XINGTU_DATA_PATH=./data

# ===== 日志配置 =====
XINGTU_LOG_LEVEL=INFO

# ===== 嵌入模型配置 =====
# 选项: openai | ollama | sentence-transformers | huggingface
XINGTU_EMBEDDING_PROVIDER=openai

# ===== OpenAI 配置 =====
# OpenAI API Key（必填，如果使用 OpenAI）
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API Base URL（可选，用于代理或兼容服务）
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 模型配置
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4

# ===== Ollama 配置 =====
# Ollama 服务地址（如果使用 Ollama）
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ===== Sentence Transformers 配置 =====
# 本地模型路径（如果使用 sentence-transformers）
SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2

# ===== 资源限制 =====
# Docker 容器资源限制
XINGTU_CPU_LIMIT=2
XINGTU_MEMORY_LIMIT=4G
XINGTU_CPU_RESERVATION=1
XINGTU_MEMORY_RESERVATION=2G
