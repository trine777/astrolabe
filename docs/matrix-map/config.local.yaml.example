# 本地覆盖配置 — 复制为 config.local.yaml 后修改
# cp config.local.yaml.example config.local.yaml
#
# 优先级：CLI > 环境变量 > 本文件 > config.yaml
# ⚠️ token/secret/password 字段不允许在任何 yaml 中出现（config_loader 会阻断）
#    密钥只通过环境变量传递

# 示例：覆盖某环境的 URL（常见于本地反向代理）
# environments:
#   prod:
#     url: https://matrix.internal.example.com

# 示例：本地测试时改 default_env
# default_env: local

# 示例：延长 timeout（冷启动慢时）
# environments:
#   prod:
#     timeout_sec: 60

# 示例：改 token 对应的环境变量名（如团队用统一的 SECRET_MANAGER_XXX）
# environments:
#   prod:
#     token_env: COMPANY_MATRIX_TOKEN
